<mxfile host="app.diagrams.net">
  <diagram name="BPMN Corrected Process" id="bpmn_corrected_process">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Pool and Lanes -->
        <mxCell id="pool" value="Restaurant Reservation, Order, Inventory and Sales Process" style="swimlane;horizontal=0;startSize=30;fillColor=#ffffff;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1500" height="820" as="geometry"/>
        </mxCell>
        <mxCell id="lane_customer" value="Customer / Visitor" style="swimlane;horizontal=0;startSize=28;fillColor=#f8f9fa;strokeColor=#cccccc;" vertex="1" parent="pool">
          <mxGeometry x="30" y="0" width="1470" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="lane_reservation" value="Reservation System" style="swimlane;horizontal=0;startSize=28;fillColor=#ffffff;strokeColor=#cccccc;" vertex="1" parent="pool">
          <mxGeometry x="30" y="110" width="1470" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="lane_service" value="Restaurant Service" style="swimlane;horizontal=0;startSize=28;fillColor=#f8f9fa;strokeColor=#cccccc;" vertex="1" parent="pool">
          <mxGeometry x="30" y="260" width="1470" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="lane_kitchen" value="Kitchen" style="swimlane;horizontal=0;startSize=28;fillColor=#ffffff;strokeColor=#cccccc;" vertex="1" parent="pool">
          <mxGeometry x="30" y="380" width="1470" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="lane_inventory" value="Inventory System" style="swimlane;horizontal=0;startSize=28;fillColor=#f8f9fa;strokeColor=#cccccc;" vertex="1" parent="pool">
          <mxGeometry x="30" y="500" width="1470" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="lane_pos" value="Product Sales / POS" style="swimlane;horizontal=0;startSize=28;fillColor=#ffffff;strokeColor=#cccccc;" vertex="1" parent="pool">
          <mxGeometry x="30" y="620" width="1470" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="lane_finance" value="Finance / Reporting" style="swimlane;horizontal=0;startSize=28;fillColor=#f8f9fa;strokeColor=#cccccc;" vertex="1" parent="pool">
          <mxGeometry x="30" y="720" width="1470" height="100" as="geometry"/>
        </mxCell>

        <!-- Customer -->
        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_customer">
          <mxGeometry x="40" y="35" width="40" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="submit_request" value="Submit reservation request&#xa;(date, time, guests, special requests)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_customer">
          <mxGeometry x="110" y="25" width="210" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="customer_arrives" value="Arrive for dining / guesthouse&#xa;or purchase traditional products" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_customer">
          <mxGeometry x="1190" y="25" width="230" height="60" as="geometry"/>
        </mxCell>

        <!-- Reservation system -->
        <mxCell id="receive_request" value="Receive reservation request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_reservation">
          <mxGeometry x="110" y="35" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="check_availability" value="Check real-time table / room availability" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_reservation">
          <mxGeometry x="350" y="35" width="230" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="gw_available" value="X&#xa;Available?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_reservation">
          <mxGeometry x="620" y="25" width="95" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="create_reservation" value="Create and confirm reservation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_reservation">
          <mxGeometry x="760" y="20" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="reject_reservation" value="Reject request or suggest alternative slot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_reservation">
          <mxGeometry x="760" y="90" width="240" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="reservation_data" value="Reservation History" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_reservation">
          <mxGeometry x="1020" y="20" width="145" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="notify_staff" value="Notify restaurant / guesthouse staff" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_reservation">
          <mxGeometry x="1190" y="20" width="230" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="end_rejected" value="End" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_reservation">
          <mxGeometry x="1045" y="100" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Service -->
        <mxCell id="record_order" value="Record customer order" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_service">
          <mxGeometry x="110" y="30" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="associate_order" value="Associate order with table / reservation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_service">
          <mxGeometry x="350" y="30" width="230" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="send_kitchen" value="Send order to kitchen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_service">
          <mxGeometry x="620" y="30" width="190" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="order_data" value="Order Details" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_service">
          <mxGeometry x="850" y="25" width="145" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="serve_customer" value="Serve food / service to customer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_service">
          <mxGeometry x="1040" y="30" width="220" height="55" as="geometry"/>
        </mxCell>

        <!-- Kitchen -->
        <mxCell id="prepare_food" value="Prepare food / process order" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_kitchen">
          <mxGeometry x="350" y="30" width="230" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="gw_ingredients" value="X&#xa;Ingredients available?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_kitchen">
          <mxGeometry x="620" y="20" width="115" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="update_usage" value="Update ingredient usage / sold items" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_kitchen">
          <mxGeometry x="780" y="30" width="230" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="inform_unavailable" value="Inform service staff and suggest alternative" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_kitchen">
          <mxGeometry x="780" y="90" width="240" height="55" as="geometry"/>
        </mxCell>

        <!-- Inventory -->
        <mxCell id="update_stock" value="Update stock quantities" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_inventory">
          <mxGeometry x="110" y="30" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="inventory_record" value="Inventory Record" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_inventory">
          <mxGeometry x="350" y="25" width="145" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="check_stock" value="Check stock level" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_inventory">
          <mxGeometry x="535" y="30" width="170" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="gw_low_stock" value="X&#xa;Low stock?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="lane_inventory">
          <mxGeometry x="750" y="20" width="100" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="notify_inventory" value="Notify inventory / supply manager" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane_inventory">
          <mxGeometry x="900" y="30" width="230" height="55" as="geometry"/>
        </mxCell>

        <!-- POS -->
        <mxCell id="register_product" value="Register traditional products&#xa;(cheese, wine, jam, etc.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_pos">
          <mxGeometry x="110" y="25" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="update_product" value="Update product price and quantity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_pos">
          <mxGeometry x="370" y="25" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="process_sale" value="Process product sale" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="lane_pos">
          <mxGeometry x="630" y="25" width="190" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="sales_data" value="Sales Transaction" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_pos">
          <mxGeometry x="860" y="20" width="155" height="65" as="geometry"/>
