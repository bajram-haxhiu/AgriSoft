        </mxCell>
        <mxCell id="generate_reports" value="Generate reports and provide analytics to management" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_finance">
          <mxGeometry x="400" y="95" width="280" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="end_success" value="End" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane_finance">
          <mxGeometry x="730" y="102" width="40" height="40" as="geometry"/>
        </mxCell>

        <!-- Sequence Flows -->
        <mxCell id="e1" edge="1" parent="lane_customer" source="start" target="submit_request" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" edge="1" parent="pool" source="submit_request" target="receive_request" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" edge="1" parent="lane_reservation" source="receive_request" target="check_availability" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" edge="1" parent="lane_reservation" source="check_availability" target="gw_available" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" value="Yes" edge="1" parent="lane_reservation" source="gw_available" target="create_reservation" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" value="No" edge="1" parent="lane_reservation" source="gw_available" target="reject_reservation" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" edge="1" parent="lane_reservation" source="create_reservation" target="reservation_data" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" edge="1" parent="lane_reservation" source="reservation_data" target="notify_staff" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" edge="1" parent="lane_reservation" source="reject_reservation" target="end_rejected" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e10" edge="1" parent="pool" source="notify_staff" target="customer_arrives" style="endArrow=open;html=1;rounded=0;dashed=1;strokeColor=#666666;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" edge="1" parent="pool" source="customer_arrives" target="record_order" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e12" edge="1" parent="lane_service" source="record_order" target="associate_order" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" edge="1" parent="lane_service" source="associate_order" target="send_kitchen" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e14" edge="1" parent="lane_service" source="send_kitchen" target="order_data" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e15" edge="1" parent="pool" source="send_kitchen" target="prepare_food" style="endArrow=open;html=1;rounded=0;dashed=1;strokeColor=#666666;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e16" edge="1" parent="lane_kitchen" source="prepare_food" target="gw_ingredients" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e17" value="Yes" edge="1" parent="lane_kitchen" source="gw_ingredients" target="update_usage" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e18" value="No" edge="1" parent="lane_kitchen" source="gw_ingredients" target="inform_unavailable" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e19" edge="1" parent="pool" source="update_usage" target="update_stock" style="endArrow=open;html=1;rounded=0;dashed=1;strokeColor=#666666;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e20" edge="1" parent="pool" source="update_usage" target="serve_customer" style="endArrow=open;html=1;rounded=0;dashed=1;strokeColor=#666666;"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e21" edge="1" parent="lane_inventory" source="update_stock" target="inventory_record" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e22" edge="1" parent="lane_inventory" source="inventory_record" target="check_stock" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e23" edge="1" parent="lane_inventory" source="check_stock" target="gw_low_stock" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e24" value="Yes" edge="1" parent="lane_inventory" source="gw_low_stock" target="notify_inventory" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="e25" edge="1" parent="pool" source="customer_arrives" target="register_product" style="endArrow=block;html=1;rounded=0;strokeColor=#000000;"><mxGeometry relative="1" as="geometry"/></mxCell>
