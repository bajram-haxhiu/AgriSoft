        <mxCell id="maintain_history" value="Maintain purchase / sales history" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_pos">
          <mxGeometry x="1060" y="25" width="230" height="55" as="geometry"/>
        </mxCell>

        <!-- Finance -->
        <mxCell id="calculate_bill" value="Calculate total bill automatically" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="lane_finance">
          <mxGeometry x="350" y="25" width="230" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="generate_invoice" value="Generate receipt / invoice" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="lane_finance">
          <mxGeometry x="630" y="25" width="220" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="finance_data" value="Financial and transaction data" style="shape=document;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane_finance">
          <mxGeometry x="900" y="20" width="180" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="collect_data" value="Collect data&#xa;(sales, reservations, inventory)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="lane_finance">
